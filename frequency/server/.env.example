# Neon Postgres connection string (includes ?sslmode=require)
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require

# Random long string — signs session cookies and the Google-pending token.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# OAuth client id from Google Cloud Console (Credentials → OAuth client ID →
# Web application). Leave blank to keep Google sign-in disabled.
GOOGLE_CLIENT_ID=

# Comma-separated list of allowed frontend origins (Vercel domains), e.g.
# https://frequency-drab.vercel.app,https://frequency.example.com
FRONTEND_ORIGIN=

PORT=8787
